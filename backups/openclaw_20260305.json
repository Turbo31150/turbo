  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "maxBytes": 20971520,
        "models": [
          {
            "type": "cli",
            "command": "whisper",
            "args": [
              "--model",
              "turbo",
              "--language",
              "fr",
              "{{MediaPath}}"
            ],
            "timeoutSeconds": 45
          }
        ]
      }
    },
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "*"
      ]
    },
    "exec": {
      "host": "sandbox"
    }
  },
  "messages": {
    "queue": {
      "mode": "collect",
      "debounceMs": 500,
      "cap": 20,
      "drop": "summarize"
    },
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "inbound",
      "provider": "edge",
      "edge": {
        "enabled": true,
        "voice": "fr-FR-DeniseNeural",
        "outputFormat": "audio-24khz-48kbitrate-mono-mp3"
      },
      "maxTextLength": 4000,
      "timeoutMs": 30000
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 120
    }
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "minIntervalMs": 120000,
    "queueOverflow": "drop"
