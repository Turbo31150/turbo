"[project]\nname = \"turbo\"\nversion = \"0.1.0\"\ndescription = \"JARVIS Orchestrator - Multi-engine AI agent powered by Claude Agent SDK\"\nrequires-python = \">=3.10\"\ndependencies = [\n    \"claude-agent-sdk>=0.1.35\",\n    \"httpx>=0.27.0\",\n    \"python-dotenv>=1.0.0\",\n    \"ccxt>=4.0.0\",\n    \"textual>=1.0.0\",\n    \"pystray>=0.19.0\",\n    \"pillow>=10.0.0\",\n    \"keyboard>=0.13.5\",\n    \"numpy>=2.0.0\",\n    \"sounddevice>=0.5.0\",\n    \"fastapi>=0.129.0\",\n    \"uvicorn>=0.40.0\",\n    \"websockets>=16.0\",\n    \"openwakeword>=0.6.0\",\n    \"edge-tts>=6.1.0\",\n    \"faster-whisper>=1.1.0\",\n    \"onnxruntime>=1.24.2\",\n    \"scipy>=1.15.3\",\n    \"datasets>=4.6.1\",\n    \"pytest-asyncio>=1.3.0\",\n]\n\n[project.scripts]\nturbo = \"main:main_sync\"\n\n[tool.pytest.ini_options]\ntestpaths = [\"tests\"]\nasyncio_mode = \"strict\"\naddopts = \"--ignore=tests/test_final.py --ignore=tests/test_pipelines_batch2.py --ignore=tests/test_pipelines_batch3.py --ignore=tests/test_pipelines_batch4.py --ignore=tests/test_pipelines_batch5.py --ignore=tests/test_pipelines_batch6.py --ignore=tests/test_pipelines_batch7.py --ignore=tests/test_pipelines_live.py --ignore=tests/test_domino_live.py --ignore=tests/test_domino_executor.py --ignore=tests/test_pattern_agents.py --ignore=tests/test_quick.py\"\nfilterwarnings = [\n    \"ignore::RuntimeWarning\",\n    \"ignore::DeprecationWarning\",\n]\n"